PROFILE_NAME=default
APP_DATA_DIR=runtime/profiles/default
GAROON_BASE_URL=https://example.cybozu.com/g
GAROON_USERNAME=your-username
GAROON_PASSWORD=your-password
GAROON_START_DAYS_OFFSET=0
GAROON_END_DAYS_OFFSET=92
LOG_LEVEL=INFO
CALDAV_URL=https://caldav.example.com/
CALDAV_USERNAME=your-caldav-username
CALDAV_PASSWORD=your-caldav-password
CALDAV_CALENDAR_NAME=Garoon Sync Test
CALDAV_DRY_RUN=false
CALDAV_DIAGNOSTIC_DUMP_FAILED_ICS=false
CALDAV_DIAGNOSTIC_DUMP_SUCCESS_ICS=false
CALDAV_DIAGNOSTIC_DUMP_UID_LOOKUP_JSON=false
DRY_RUN_WARN_CREATE_COUNT=10
DRY_RUN_WARN_DELETE_COUNT=10

# Optional overrides:
# OUTPUT_JSON_PATH=data/events.json
# GAROON_TARGET_USER=your-user-id
# GAROON_TARGET_CALENDAR=your-calendar-id
